#!/bin/sh

set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

submodule_paths=$(git config -f .gitmodules --get-regexp '^submodule\..*\.path$' | cut -d' ' -f2)

if [ -z "$submodule_paths" ]; then
    echo "No submodules configured"
    exit 0
fi

git submodule foreach --recursive '
  printf "Updating %s\n" "$name"
  git pull --rebase
  git push
'

git add $submodule_paths

if git diff --cached --quiet --exit-code -- $submodule_paths; then
    echo "No updated submodule refs to commit"
    exit 0
fi

git commit -m "chore(submodules): updated git submodules"
